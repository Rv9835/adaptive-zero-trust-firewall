# ============================================================
# Adaptive Zero Trust Firewall (PS001) — Environment Variables
# ============================================================

# --- Proxy Gateway ---
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=10s

# Proxy targets: comma-separated path=url pairs
# Example: /api=http://api-backend:9090,/web=http://web-app:3000
PROXY_TARGETS=/=http://localhost:9090

# Rate limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
RATE_LIMIT_CLEANUP_INTERVAL=5m

# Auth (disabled in Phase 1)
AUTH_ENABLED=false
AUTH_SERVICE_URL=http://localhost:8081

# Downstream services (used in Phase 2+)
ML_ENGINE_URL=http://localhost:8082
POLICY_ENGINE_URL=http://localhost:8181

# Logging
LOG_LEVEL=info
ENV=development

# --- MongoDB Atlas (used in Phase 2+) ---
MONGODB_URI=mongodb+srv://chamandb:chaman123@firewall.qvbiaop.mongodb.net/?appName=firewall
MONGODB_DATABASE=firewall

# --- Redis ---
REDIS_URL=redis://localhost:6379
